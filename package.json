{
  "name": "@varshinicb1/clear",
  "version": "0.3.0",
  "description": "Clear — English to Machine Code. Nothing between.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "clear": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsx src/index.ts check",
    "test": "node --test dist/**/*.test.js",
    "test:coverage": "c8 --reporter=lcov --reporter=text node --test dist/**/*.test.js",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 node --test dist/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clear",
    "language",
    "specification",
    "declarative",
    "agent-first"
  ],
  "author": "varshinicb1 (https://github.com/varshinicb1)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.1-rc"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "uuid": "^14.0.1"
  }
}
