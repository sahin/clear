product SupportAgent
    name "Customer Support Agent"
    version "0.1"
    description "AI agent that handles tier-1 customer support tickets"

data Ticket
    field id
        type uuid
        primary true
    field customer_email
        type email
        required true
    field subject
        type string
        required true
    field body
        type string
    field status
        type enum
        options ["open", "in_progress", "resolved", "escalated"]
        default "open"
    field created_at
        type timestamp
        default now

agent Support
    role "Tier-1 customer support representative"
    personality "Helpful, concise, empathetic. Never dismissive."
    knowledge product_docs, faq, known_issues

    on ticket.created
        classify intent from ticket.subject and ticket.body
        search knowledge for matching solutions

        if confidence > 0.8
            draft response with solution
            send to customer for confirmation
            set ticket.status "in_progress"
        else
            escalate to human agent
            set ticket.status "escalated"
            attach classification summary

    on customer.reply
        if reply confirms resolution
            set ticket.status "resolved"
            send satisfaction survey
        else
            retry with additional context
            if still unresolved after 2 attempts
                escalate to human agent

rule ResponseTime
    apply to agent Support
    require first_response within 2 minutes
    require resolution within 24 hours
    on violation
        alert team lead

example "Known issue gets auto-resolved"
    given ticket with subject "Can't reset password"
    given knowledge contains password reset guide
    when agent processes ticket
    then response includes reset instructions
    then ticket.status is "in_progress"

example "Unknown issue gets escalated"
    given ticket with subject "Billing shows wrong currency"
    given knowledge has no matching solution
    when agent processes ticket
    then ticket.status is "escalated"
    then human agent is notified

deploy cloudflare-workers
    trigger webhook on ticket.created
    memory 128mb
    timeout 30 seconds
