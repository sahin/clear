// Rule: TaskValidation
function validateTaskValidation(data: Record<string, any>): string[] {
  const errors: string[] = []
  if (!data['title'] || String(data['title']).trim() === '') errors.push('title is required')
  if (data['due_date'] && new Date(data['due_date']).getTime() <= Date.now()) errors.push('due_date must be in the future')
  // TODO: validate assignee exists in User
  return errors
}

