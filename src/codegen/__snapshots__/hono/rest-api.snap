// API: REST /tasks
app.get('/tasks', async (c) => {
  try {
    let result = [...tasks]
    if (c.req.query('status')) result = result.filter(i => String(i['status']) === c.req.query('status'))
    if (c.req.query('priority')) result = result.filter(i => String(i['priority']) === c.req.query('priority'))
    if (c.req.query('assignee')) result = result.filter(i => String(i['assignee']) === c.req.query('assignee'))
    result.sort((a: any, b: any) => {
      const av = a['created_at']
      const bv = b['created_at']
      if (!av && !bv) return 0
      if (!av) return 1
      if (!bv) return -1
      return av < bv ? 1 : av > bv ? -1 : 0
    })
    const page = parseInt(c.req.query('page') || '1')
    const start = (page - 1) * 20
    return c.json({
      data: result.slice(start, start + 20),
      total: result.length,
      page,
      limit: 20,
      totalPages: Math.ceil(result.length / 20)
    })
  } catch (err: any) {
    console.error(err)
    return c.json({ error: err.message }, 500)
  }
})
app.get('/tasks/:id', async (c) => {
  try {
    const id = c.req.param('id')
    const item = tasks.find(i => i.id === id)
    if (!item) {
      return c.json({ error: 'not found' }, 404)
