// Rule: TaskValidation
function validateTaskValidation(data: Record<string, any>): string[] {
  const errors: string[] = []
  if (!data['title'] || String(data['title']).trim() === '') errors.push('title is required')
  if (data['due_date'] && new Date(data['due_date']).getTime() <= Date.now()) errors.push('due_date must be in the future')
  // TODO: validate assignee exists in User
  return errors
}

// App setup
const app = express()
app.use(cors())
app.use(express.json())

// API: REST /tasks
app.get('/tasks', (req: Request, res: Response) => {
  try {
    let result = [...tasks]
    if (req.query['status']) result = result.filter(i => String(i['status']) === req.query['status'])
    if (req.query['priority']) result = result.filter(i => String(i['priority']) === req.query['priority'])
    if (req.query['assignee']) result = result.filter(i => String(i['assignee']) === req.query['assignee'])
    result.sort((a: any, b: any) => {
      const av = a['created_at']
      const bv = b['created_at']
      if (!av && !bv) return 0
      if (!av) return 1
      if (!bv) return -1
      return av < bv ? 1 : av > bv ? -1 : 0
    })
    const page = parseInt(req.query.page as string) || 1
    const start = (page - 1) * 20
    res.json({
      data: result.slice(start, start + 20),
      total: result.length,
      page,
      limit: 20,
      totalPages: Math.ceil(result.length / 20)
    })
  } catch (err: any) {
    console.error(err)
    res.status(500).json({ error: err.message })
  }
})
app.get('/tasks/:id', (req: Request, res: Response) => {
  try {
    const item = tasks.find(i => i.id === req.params.id)
    if (!item) {
      res.status(404).json({ error: 'not found' })
      return
    }
    const result = { ...item }
    result['assignee'] = users.find((r: any) => r.id === item['assignee']) ?? null
    res.json(result)
  } catch (err: any) {
    console.error(err)
    res.status(500).json({ error: err.message })
  }
})
app.post('/tasks', (req: Request, res: Response) => {
  try {
    const { title, description, priority, assignee, due_date } = req.body
    const validationErrors: string[] = []
    validationErrors.push(...validateTaskValidation(req.body))
    if (validationErrors.length > 0) {
      res.status(400).json({ errors: validationErrors })
      return
    }
    const item: Task = {
      id: uuidv4(),
      title,
      description,
      priority,
      assignee,
      due_date,
      status: 'todo',
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString(),
    }
    tasks.push(item)
    res.status(201).json(item)
  } catch (err: any) {
    console.error(err)
    res.status(500).json({ error: err.message })
  }
})
app.put('/tasks/:id', (req: Request, res: Response) => {
  try {
    const index = tasks.findIndex(i => i.id === req.params.id)
    if (index === -1) {
      res.status(404).json({ error: 'not found' })
