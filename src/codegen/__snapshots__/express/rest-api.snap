    if (req.body['assignee'] !== undefined) updates['assignee'] = req.body['assignee']
    if (req.body['due_date'] !== undefined) updates['due_date'] = req.body['due_date']
    updates['updated_at'] = new Date().toISOString()
    tasks[index] = { ...tasks[index], ...updates, id: req.params.id }
    res.status(200).json(tasks[index])
  } catch (err: any) {
    console.error(err)
    res.status(500).json({ error: err.message })
  }
})
app.delete('/tasks/:id', (req: Request, res: Response) => {
  try {
    const index = tasks.findIndex(i => i.id === req.params.id)
    if (index === -1) {
      res.status(404).json({ error: 'not found' })
